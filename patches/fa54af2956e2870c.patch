+	def register(self, question):
+		if not question:
+			return
+		inquiries = self.m.state.inquiries
+		for other in inquiries:
+			if self.same_question(question, other["question"]):
+				other["alternative_questions"].append(question)
+				return
+		inquiries.append({
+			"question": question,
