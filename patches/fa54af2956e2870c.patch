+	def _extract_questions(self, block):
+		questions = []
+		for match in _QUESTION_RE.findall(block):
+			q = _WS_RE.sub(" ", match).strip()
+			if q:
+				questions.append(q)
+		return questions
+
+	def is_complete(self=None):
+		if self is None:
+			return False
+		inquiries = getattr(self.m.state, "inquiries", None)
+		if not inquiries:
+			return True
+		for inquiry in inquiries:
+			if not inquiry.get("answer"):
+				return False
+		return True
 
