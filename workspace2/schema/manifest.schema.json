{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/workspace2/manifest.schema.json",
  "title": "PackageManifest",
  "type": "object",
  "required": ["caseId", "branch", "authorityTrust", "sourceSummary", "fitSummary", "fitFindingSummary", "recommendedFirstStop", "whyOpenThis", "artifactBundle", "artifacts", "artifactGuidance", "notes"],
  "properties": {
    "caseId": { "type": "string" },
    "branch": { "type": "string" },
    "recommendedFirstStop": { "type": "string" },
    "whyOpenThis": { "type": "string" },
    "authorityTrust": {
      "type": "object",
      "required": [
        "authorityCount",
        "verifiedQuoteCount",
        "paraphraseCount",
        "missingCount",
        "severity",
        "label",
        "advisory"
      ],
      "properties": {
        "authorityCount": { "type": "integer", "minimum": 0 },
        "verifiedQuoteCount": { "type": "integer", "minimum": 0 },
        "paraphraseCount": { "type": "integer", "minimum": 0 },
        "missingCount": { "type": "integer", "minimum": 0 },
        "severity": { "type": "string", "enum": ["info", "warning"] },
        "label": {
          "type": "string",
          "enum": ["fully_verified", "mixed_support", "paraphrase_heavy"]
        },
        "advisory": { "type": "string" }
      },
      "additionalProperties": false
    },
    "sourceSummary": {
      "type": "object",
      "required": [
        "authorityCount",
        "sourceVerifiedCount",
        "sourceNormalizedCount",
        "fullySourceVerified",
        "fullySourceNormalized",
        "sourceStatus"
      ],
      "properties": {
        "authorityCount": { "type": "integer", "minimum": 0 },
        "sourceVerifiedCount": { "type": "integer", "minimum": 0 },
        "sourceNormalizedCount": { "type": "integer", "minimum": 0 },
        "fullySourceVerified": { "type": "boolean" },
        "fullySourceNormalized": { "type": "boolean" },
        "sourceStatus": { "type": "string" }
      },
      "additionalProperties": false
    },
    "fitSummary": {
      "type": "object",
      "required": [
        "authorityCount",
        "directCount",
        "analogicalCount",
        "recordSupportCount",
        "fitStatus"
      ],
      "properties": {
        "authorityCount": { "type": "integer", "minimum": 0 },
        "directCount": { "type": "integer", "minimum": 0 },
        "analogicalCount": { "type": "integer", "minimum": 0 },
        "recordSupportCount": { "type": "integer", "minimum": 0 },
        "fitStatus": { "type": "string" }
      },
      "additionalProperties": false
    },
    "fitFindingSummary": {
      "type": "object",
      "required": ["hasFitFinding", "fitFinding", "fitFindingNote"],
      "properties": {
        "hasFitFinding": { "type": "boolean" },
        "fitFinding": {
          "type": "string",
          "enum": ["direct_only", "analogical_support", "record_support_heavy", "unclassified"]
        },
        "fitFindingNote": { "type": "string" }
      },
      "additionalProperties": false
    },
    "artifactBundle": { "type": "string" },
    "artifacts": {
      "type": "array",
      "items": { "type": "string" }
    },
    "artifactGuidance": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["path", "whyOpenThis"],
        "properties": {
          "path": { "type": "string" },
          "whyOpenThis": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "notes": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
