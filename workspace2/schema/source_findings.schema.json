{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/workspace2/source_findings.schema.json",
  "title": "SourceFindings",
  "type": "object",
  "required": ["generatedAt", "summary", "findings"],
  "properties": {
    "generatedAt": { "type": "string" },
    "summary": {
      "type": "object",
      "required": ["caseCount", "fullyNormalizedCases", "partiallyNormalizedCases"],
      "properties": {
        "caseCount": { "type": "integer" },
        "fullyNormalizedCases": { "type": "integer" },
        "partiallyNormalizedCases": { "type": "integer" }
      },
      "additionalProperties": false
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["caseId", "branch", "severity", "title", "detail"],
        "properties": {
          "caseId": { "type": "string" },
          "branch": { "type": "string" },
          "severity": { "type": "string", "enum": ["info", "warning"] },
          "title": { "type": "string" },
          "detail": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
