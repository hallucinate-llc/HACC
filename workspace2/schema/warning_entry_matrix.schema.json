{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/workspace2/warning_entry_matrix.schema.json",
  "title": "WarningEntryMatrix",
  "type": "object",
  "required": ["generatedAt", "cases"],
  "properties": {
    "generatedAt": { "type": "string" },
    "refreshRuntime": {
      "type": "object",
      "required": ["status", "running", "startedAt", "completedAt", "elapsedSeconds", "elapsedHuman"],
      "properties": {
        "status": { "type": "string" },
        "running": { "type": "boolean" },
        "startedAt": { "type": ["string", "null"] },
        "completedAt": { "type": ["string", "null"] },
        "elapsedSeconds": { "type": ["number", "null"] },
        "elapsedHuman": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "caseId",
          "branch",
          "authorityTrust",
          "warningLabel",
          "warningEntryCount",
          "warningCounts",
          "warnedKinds",
          "packagePath"
        ],
        "properties": {
          "caseId": { "type": "string" },
          "branch": { "type": "string" },
          "authorityTrust": {
            "type": "string",
            "enum": ["mixed_support", "paraphrase_heavy"]
          },
          "warningLabel": {
            "type": "string",
            "enum": ["mixed_support", "paraphrase_heavy"]
          },
          "warningEntryCount": { "type": "integer", "minimum": 1 },
          "warningCounts": {
            "type": "object",
            "propertyNames": {
              "enum": ["mixed_support", "paraphrase_heavy"]
            },
            "additionalProperties": { "type": "integer", "minimum": 0 }
          },
          "warnedKinds": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          },
          "packagePath": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
