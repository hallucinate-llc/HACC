{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/workspace2/case_instance.schema.json",
  "title": "CaseInstanceJsonLd",
  "type": "object",
  "required": ["@context", "@graph"],
  "properties": {
    "@context": { "type": "string" },
    "@graph": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "type"],
        "properties": {
          "id": { "type": "string" },
          "type": {
            "oneOf": [
              { "type": "string" },
              {
                "type": "array",
                "items": { "type": "string" }
              }
            ]
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}
