{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/workspace2/trust_matrix.schema.json",
  "title": "TrustMatrix",
  "type": "object",
  "required": ["generatedAt", "cases"],
  "properties": {
    "generatedAt": { "type": "string" },
    "staleWhileRefreshing": { "type": "boolean" },
    "refreshRuntime": {
      "type": "object",
      "required": ["status", "running", "startedAt", "completedAt", "elapsedSeconds", "elapsedHuman"],
      "properties": {
        "status": { "type": "string" },
        "running": { "type": "boolean" },
        "startedAt": { "type": "string" },
        "completedAt": { "type": ["string", "null"] },
        "elapsedSeconds": { "type": ["number", "null"] },
        "elapsedHuman": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "caseId",
          "branch",
          "activeOutcome",
          "authorityTrust",
          "primaryKind",
          "hasEntryWarnings",
          "warningEntryCount",
          "packagePath"
        ],
        "properties": {
          "caseId": { "type": "string" },
          "branch": { "type": "string" },
          "activeOutcome": { "type": "string" },
          "authorityTrust": {
            "type": "string",
            "enum": ["fully_verified", "mixed_support", "paraphrase_heavy"]
          },
          "primaryKind": { "type": "string" },
          "hasEntryWarnings": { "type": "boolean" },
          "warningEntryCount": { "type": "integer", "minimum": 0 },
          "packagePath": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
