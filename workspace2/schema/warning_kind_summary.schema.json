{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/workspace2/warning_kind_summary.schema.json",
  "title": "WarningKindSummary",
  "type": "object",
  "required": ["generatedAt", "summary", "singleCaseGuide", "kinds"],
  "properties": {
    "generatedAt": { "type": "string" },
    "refreshRuntime": {
      "type": "object",
      "required": ["status", "running", "startedAt", "completedAt", "elapsedSeconds", "elapsedHuman"],
      "properties": {
        "status": { "type": "string" },
        "running": { "type": "boolean" },
        "startedAt": { "type": ["string", "null"] },
        "completedAt": { "type": ["string", "null"] },
        "elapsedSeconds": { "type": ["number", "null"] },
        "elapsedHuman": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "summary": {
      "type": "object",
      "required": ["kindCount", "caseCount"],
      "properties": {
        "kindCount": { "type": "integer", "minimum": 0 },
        "caseCount": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "singleCaseGuide": {
      "type": ["object", "null"],
      "required": ["caseId", "recommendedFirstStop", "whyOpenThis"],
      "properties": {
        "caseId": { "type": "string" },
        "recommendedFirstStop": { "type": "string" },
        "whyOpenThis": { "type": "string" }
      },
      "additionalProperties": false
    },
    "kinds": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["kind", "warningCaseCount", "warningLabels"],
        "properties": {
          "kind": { "type": "string" },
          "warningCaseCount": { "type": "integer", "minimum": 1 },
          "warningLabels": {
            "type": "object",
            "propertyNames": {
              "enum": ["mixed_support", "paraphrase_heavy"]
            },
            "additionalProperties": { "type": "integer", "minimum": 0 }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
