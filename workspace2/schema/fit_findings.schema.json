{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/workspace2/fit_findings.schema.json",
  "title": "FitFindings",
  "type": "object",
  "required": ["generatedAt", "summary", "findings"],
  "properties": {
    "generatedAt": { "type": "string" },
    "refreshRuntime": {
      "type": "object",
      "required": ["status", "running", "startedAt", "completedAt", "elapsedSeconds", "elapsedHuman"],
      "properties": {
        "status": { "type": "string" },
        "running": { "type": "boolean" },
        "startedAt": { "type": ["string", "null"] },
        "completedAt": { "type": ["string", "null"] },
        "elapsedSeconds": { "type": ["number", "null"] },
        "elapsedHuman": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "summary": {
      "type": "object",
      "required": ["caseCount", "directOnlyCases", "analogicalCases", "recordSupportCases"],
      "properties": {
        "caseCount": { "type": "integer", "minimum": 0 },
        "directOnlyCases": { "type": "integer", "minimum": 0 },
        "analogicalCases": { "type": "integer", "minimum": 0 },
        "recordSupportCases": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["caseId", "branch", "severity", "title", "detail"],
        "properties": {
          "caseId": { "type": "string" },
          "branch": { "type": "string" },
          "severity": { "type": "string", "enum": ["info", "warning"] },
          "title": { "type": "string" },
          "detail": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
