    },
    {
      "id": "excerpt:california_mobile_home",
      "type": "AuthorityExcerpt",
      "authority": "authority:california_mobile_home",
      "excerptText": "California Mobile Home is used here as a paraphrased reminder that reasonable accommodation analysis must stay tied to how access works in practice.",
