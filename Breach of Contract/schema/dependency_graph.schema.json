{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/workspace2/dependency_graph.schema.json",
  "title": "DependencyGraphExport",
  "type": "object",
  "required": ["branch", "activeOutcome", "nodes", "edges"],
  "properties": {
    "branch": { "type": "string" },
    "activeOutcome": { "type": "string" },
    "nodes": {
      "type": "array",
      "items": { "type": "string" }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "array",
        "minItems": 2,
        "maxItems": 3,
        "items": { "type": "string" }
      }
    }
  },
  "additionalProperties": false
}
