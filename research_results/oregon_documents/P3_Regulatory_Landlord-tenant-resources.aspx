					<button class="collapsed btn btn-link or-accordion-panel-btn" href="#utility" aria-controls="utility" data-toggle="collapse" aria-expanded="false"><div class="panel-heading" id="eff0a8ab-ace2-432d-80de-47bfbe1c296b">
						<div class="or-accordion-heading">
							<div class="or-accordion-heading-title">
								<p class="panel-title">Utility Bill Payment Assistance </p>
							</div><span class="or-accordion-heading-collapse" role="img" aria-hidden="true"></span>
						</div>
					</div></button>
				</h2><div class="panel-collapse collapse" id="utility" >
					<div class="panel-body">
						<div class="or-accordion-content-field">
							<div class="ExternalClassCF7551275397401BBF68097A4042A6B1"><div><p>
      ​For utility bill payment and energy assistance, please contact your local Community Action Agency. You can learn more about this program and get contact information on the 
         
            <a href="/ohcs/energy-weatherization/Pages/utility-bill-payment-assistance.aspx">
               OHCS Utility Bill Payment web page</a>.&#160;​<br></p></div></div>
						</div>
					</div>
				</div>
			</div><div class="panel panel-default or-accordion-panel" id="panel-weatherization">
				<h2>
					<button class="collapsed btn btn-link or-accordion-panel-btn" href="#weatherization" aria-controls="weatherization" data-toggle="collapse" aria-expanded="false"><div class="panel-heading" id="59fb3562-3349-48fd-82eb-f6ac8ae1993e">
						<div class="or-accordion-heading">
							<div class="or-accordion-heading-title">
