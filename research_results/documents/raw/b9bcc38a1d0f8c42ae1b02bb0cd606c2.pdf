                    </div>

                    

                    

                        <div class="row">

                        <div class="col-md-3">
                            <!-- side navigation publishing data source -->
                            

                            <!-- side navigation menu -->
                            <nav id="OregonSideNavigation" aria-label="Site Navigation" class="or-side-navigation navmenu navmenu-default navmenu-fixed-left offcanvas-sm">
	<ul class="nav">
		<li class=""><a href="/odot/Business/OCR/Pages/About_Us.aspx">About Us</a></li><li class=""><a href="/odot/Business/OCR/Pages/Contact-Us.aspx">Contact Us</a></li><li class=""><a href="/odot/Business/OCR/Pages/Forms.aspx">Forms</a></li><li class=""><a href="/odot/Business/OCR/Pages/Events.aspx">Outreach &amp; Events</a></li><li class=""><a href="/odot/Business/OCR/Pages/News_Blast_Page.aspx">Newsletter Sign-up</a></li><li class="or-side-navigation-parent"><span class="or-side-navigation-unlinked-item">Programs</span><div>
			<ul class="or-side-navigation-submenu list-unstyled">
				<li class=""><a href="/odot/Business/OCR/Pages/Disadvantaged-Business-Enterprise.aspx">Disadvantaged Business Enterprise (DBE)</a></li><li class=""><a href="/odot/Business/OCR/Pages/Equal-Employment-Opportunity-Contractor-Compliance.aspx">Equal Employment Opportunity Contractor Compliance</a></li><li class="or-side-navigation-current"><a href="/odot/Business/OCR/Pages/Intermodal-Civil-Rights.aspx" aria-current="page">Intermodal Civil Rights</a></li><li class=""><a href="/odot/Business/OCR/Pages/Mentor-Prot%c3%a9g%c3%a9-Program-.aspx">Mentor-Prot&#233;g&#233; Program </a></li><li class=""><a href="/odot/Business/OCR/Pages/Non-Discrimination.aspx">Nondiscrimination in Federally Assisted Programs</a></li><li class=""><a href="/odot/Business/OCR/Pages/Workforce-Development.aspx">Workforce Development Program</a></li>
			</ul>
		</div></li><li class="or-side-navigation-parent"><span class="or-side-navigation-unlinked-item">Small Business</span><div>
			<ul class="or-side-navigation-submenu list-unstyled">
				<li class=""><a href="/odot/Business/OCR/Pages/Emerging-Small-Business.aspx">Emerging Small Business (ESB) Program</a></li><li class=""><a href="/odot/Business/OCR/Pages/Small-Business-Resources.aspx">Small Business Resources</a></li><li class=""><a href="/odot/Business/OCR/Pages/SBDP.aspx">Small Business Development Program</a></li><li class=""><a href="/odot/Business/OCR/Pages/SBDP-projects.aspx">Projects Eligible for Small Business Development Program</a></li><li class=""><a href="/odot/Business/OCR/Pages/SBDP-Committee.aspx">Small Business Development Program Advisory Committee</a></li><li class=""><a href="/odot/Business/OCR/Pages/ESB-SBDP-Compare.aspx">Comparing Small Business Programs</a></li>
			</ul>
		</div></li>
