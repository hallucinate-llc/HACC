        <meta name="application-name" content="Nondiscrimination in Federally Assisted Programs : Oregon Department of Transportation" />
        <meta name="description" content="ODOT complies with Title VI of the Civil Rights Act, the Americans with Disabilities Act, and other federal nondiscrimination authorities. ODOT helps with civil rights requests about transportation in Oregon." />
        <meta name="keywords" content="Nondiscrimination, civil rights, oregon, transportation, title vi, race, color, national origin, lep, english proficiency, ada, disability, access, accessibility, environmental justice, engagement, diversity, inclusion" />
        

