</div></div><div id="vid_d090a598-14b9-4a9a-a083-9a953062252f" unselectable="on" style="display&#58;none;"></div></div><p><br></p><h2 class="ms-rteElement-Heading2">Awarded Procurements<br></h2><p></p><div class="ms-rtestate-read ms-rte-wpbox"><div class="ms-rtestate-notify  ms-rtestate-read 2626e2d8-b2da-47c1-8064-de16a18ced29" id="div_2626e2d8-b2da-47c1-8064-de16a18ced29" unselectable="on"><div id="MSOZoneCell_WebPartWPQ4" class="s4-wpcell-plain ms-webpartzone-cell ms-webpart-cell-vertical ms-fullWidth ">
	<div class="ms-webpart-chrome ms-webpart-chrome-vertical ms-webpart-chrome-fullWidth ">
	<div    id="WebPartWPQ4"  class="ms-WPBody "   style="" ><div id="ctl00_ctl40_g_2626e2d8_b2da_47c1_8064_de16a18ced29">
		<div class="list-unstyled panel-group or-accordion-list" id="accordion-ctl00_ctl40_g_2626e2d8_b2da_47c1_8064_de16a18ced29_ctl01">
