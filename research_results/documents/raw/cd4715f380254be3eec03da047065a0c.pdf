		<div class="col-md-12">
			<div id="ctl00_ctl00_MainContentPlaceHolder_PageContentPlaceHolder_PageContentPlaceHolder_RichHtmlField11_label" style='display:none'></div><div id="ctl00_ctl00_MainContentPlaceHolder_PageContentPlaceHolder_PageContentPlaceHolder_RichHtmlField11__ControlWrapper_OregonRichHtmlField" class="ms-rtestate-field" style="display:inline" ></div>
		</div>
	</div>

	<div class="row">
		<div class="col-md-8 col-sm-6">
			<div id="ctl00_ctl00_MainContentPlaceHolder_PageContentPlaceHolder_PageContentPlaceHolder_RichHtmlField12_label" style='display:none'></div><div id="ctl00_ctl00_MainContentPlaceHolder_PageContentPlaceHolder_PageContentPlaceHolder_RichHtmlField12__ControlWrapper_OregonRichHtmlField" class="ms-rtestate-field" style="display:inline" ><p>The documents below are helpful when navigating&#160;ODDS Employment Policy.&#160;<br></p><p></p><ul><li>
      <a href="/odhs/providers-partners/idd/Documents/dd-employment-team.pdf">Employment team contacts</a><br></li><li>
      <a href="/odhs/employment-first/Pages/transition-technical-assistance.aspx">Transition Technical Assistance Network (TTAN) contacts</a><br></li><li>
      <a href="/odhs/employment-first/Documents/map-odds-regional-employment-specialists-en.pdf">ODDS contact information for&#160;regional employment specialists (English)</a><br></li><li>
      <a href="/odhs/employment-first/Documents/map-odds-regional-employment-specialists-es.pdf">ODDS contact information for regional employment specialists (Español)</a><br></li><li>
      <a href="/odhs/providers-partners/idd/Documents/odds-expenditure-guidelines.pdf">ODDS Expenditure Guidelines</a><br></li><li>
      <span style="color&#58;#000000;"> 
         <a href="/odhs/employment-first/Documents/wg-employment-table-contents.pdf">ODDS Worker Guide for Employment Services Table of Contents</a></span></li><li>
      <a href="/odhs/employment-first/Documents/wg-remote-employment.pdf">Remote Employment and Day Support Activities</a>&#160;<br></li></ul></div>
		</div>
		<div class="col-md-4 col-sm-6">
			<div id="ctl00_ctl00_MainContentPlaceHolder_PageContentPlaceHolder_PageContentPlaceHolder_RichHtmlField13_label" style='display:none'></div><div id="ctl00_ctl00_MainContentPlaceHolder_PageContentPlaceHolder_PageContentPlaceHolder_RichHtmlField13__ControlWrapper_OregonRichHtmlField" class="ms-rtestate-field" style="display:inline" ><a class="odhs-btn odhs-btn-primary btn-block" href="https&#58;//public.govdelivery.com/accounts/ORDHS/subscriber/new?topic_id=ORDHS_343" title="GovDelivery website"><i class="fa fa-bell" aria-hidden="true"></i>&#160;Sign up for updates</a><br><a class="odhs-btn odhs-btn-secondary btn-block" role="button" href="mailto&#58;//employment.first@odhsoha.oregon.gov"><i class="fas fa-envelope" aria-hidden="true"></i>&#160;Questions? Email us</a><br><br></div>
		</div>
