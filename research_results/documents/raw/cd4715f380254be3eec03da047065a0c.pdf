				</div>
			</div><div class="panel panel-default or-accordion-panel" id="panel-0fa0527a-3cbd-424f-b0b5-fbf2b03ae9a0">
				<h3>
					<button class="collapsed btn btn-link or-accordion-panel-btn" href="#0fa0527a-3cbd-424f-b0b5-fbf2b03ae9a0" aria-controls="0fa0527a-3cbd-424f-b0b5-fbf2b03ae9a0" data-toggle="collapse" aria-expanded="false"><div class="panel-heading" id="bc520da0-72cd-4821-8903-3e264af320b4">
