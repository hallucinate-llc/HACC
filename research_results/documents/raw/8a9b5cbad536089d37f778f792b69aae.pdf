	<div class="row">
		<div class="col-md-4">
			<div id="ctl00_ctl00_MainContentPlaceHolder_PageContentPlaceHolder_PageContentPlaceHolder_RichHtmlField2_label" style='display:none'></div><div id="ctl00_ctl00_MainContentPlaceHolder_PageContentPlaceHolder_PageContentPlaceHolder_RichHtmlField2__ControlWrapper_OregonRichHtmlField" class="ms-rtestate-field" style="display:inline" ><div class="gov-box-style-1"><div unselectable="on"><div unselectable="on"> 
         <img class="card-img-top" src="/transparency/PublishingImages/oregonbuyshrlogo.jpg" alt="OregonBuys Contract" unselectable="on" style="width&#58;100%;" /> 
         <center unselectable="on" style="text-align&#58;left;"><h5 class="ms-rteElement-Heading5">OregonBuys Contracts&#160;<br></h5><p class="card-text" unselectable="on" style="text-align&#58;left;">This dataset contains procurement records published in OregonBuys during fiscal years 2022-2025. Contracts, and purchases made under these contracts, and non-contract purchases are included. <br></p></center></div></div><center unselectable="on" style="text-align&#58;left;">
      <a class="gov-btn gov-btn-primary" href="https&#58;//data.oregon.gov/Revenue-Expense/OregonBuys-Purchases-and-Contracts-Multi-Year-Repo/qyug-f2km/about_data" unselectable="on" style="margin-right&#58;0px;margin-bottom&#58;0px;">OregonBuys Purchases and Contracts - Multi-Year Report</a><br></center> 
   <br>
</div></div>
		</div>
		<div class="col-md-4">
			<div id="ctl00_ctl00_MainContentPlaceHolder_PageContentPlaceHolder_PageContentPlaceHolder_RichHtmlField3_label" style='display:none'></div><div id="ctl00_ctl00_MainContentPlaceHolder_PageContentPlaceHolder_PageContentPlaceHolder_RichHtmlField3__ControlWrapper_OregonRichHtmlField" class="ms-rtestate-field" style="display:inline" ><div class="gov-box-style-1"><div unselectable="on"><div unselectable="on">
         <img class="card-img-top" src="/transparency/PublishingImages/oregonbuyshrlogo.jpg" alt="OregonBuys Contract" unselectable="on" style="width&#58;100%;" />
         <center unselectable="on" style="text-align&#58;left;"><h5 class="ms-rteElement-Heading5" style="font-family&#58;calibri, arial, sans-serif;color&#58;#282828;">Statewide&#160;Price Agreements<br></h5><p class="card-text" unselectable="on" style="text-align&#58;left;">This dataset summarizes quarterly spending made under Statewide Price Agreements (PAs) for calendar years 2022-2024.<br></p> 
            <a class="gov-btn gov-btn-primary" href="https&#58;//data.oregon.gov/Revenue-Expense/Statewide-Price-Agreement-Spend-Multi-Year-Report/gart-52me/about_data" unselectable="on" style="margin-right&#58;0px;margin-bottom&#58;0px;">Statewide Price Agreement Spend - Multi-Year Report</a><br></center></div></div></div>
<br></div>
		</div>
		<div class="col-md-4">
			<div id="ctl00_ctl00_MainContentPlaceHolder_PageContentPlaceHolder_PageContentPlaceHolder_RichHtmlField4_label" style='display:none'></div><div id="ctl00_ctl00_MainContentPlaceHolder_PageContentPlaceHolder_PageContentPlaceHolder_RichHtmlField4__ControlWrapper_OregonRichHtmlField" class="ms-rtestate-field" style="display:inline" ><div class="gov-box-style-1"><div unselectable="on"><div unselectable="on">
         <img class="card-img-top" src="/transparency/PublishingImages/orpin.jpg" alt="ORPIN Contracts" unselectable="on" style="width&#58;283px;" />
         <center unselectable="on" style="text-align&#58;left;"><h5 class="ms-rteElement-Heading5">Former&#160;ORPIN Contracts<br></h5><p class="card-text" unselectable="on" style="text-align&#58;left;">This archived contracts dataset is sorted by agency and contains all versions of contracts issued in ORPIN (Oregon Procurement Information Network)&#160;from July 1, 2014 to June 30, 2021.&#160;<br></p></center></div></div><center unselectable="on" style="text-align&#58;left;"> 
      <a class="gov-btn gov-btn-primary" href="https&#58;//data.oregon.gov/Revenue-Expense/Archived-Former-ORPIN-Contracts-Multi-Year-Report/6e9e-sfc4/data" unselectable="on" style="margin-right&#58;0px;margin-bottom&#58;0px;">ORPIN - Multi-Year Contract Report</a><span style="background-color&#58;#fcfcfc;font-size&#58;1rem;"></span></center></div></div>
		</div>
