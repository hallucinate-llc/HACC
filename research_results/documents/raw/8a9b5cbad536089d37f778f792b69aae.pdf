	</div>

	<div class="row">
		<div class="col-md-3 col-sm-6">
			<div id="ctl00_ctl00_MainContentPlaceHolder_PageContentPlaceHolder_PageContentPlaceHolder_RichHtmlField7_label" style='display:none'></div><div id="ctl00_ctl00_MainContentPlaceHolder_PageContentPlaceHolder_PageContentPlaceHolder_RichHtmlField7__ControlWrapper_OregonRichHtmlField" class="ms-rtestate-field" style="display:inline" ><div class="gov-box-style-1"><div unselectable="on"><div unselectable="on"> 
         <img class="card-img-top" src="/transparency/PublishingImages/Highway.jpg" alt="Highway Construction Contracts Oregon" unselectable="on" style="width&#58;100%;" />
         <center unselectable="on"><h5 class="ms-rteElement-Heading5" style="text-align&#58;left;">Highway Construction Contracts&#160;<br></h5><p class="card-text" unselectable="on" style="text-align&#58;left;">Highway Construction contracts issued through the Oregon Department of Transportation (ODOT).<br></p><center unselectable="on">
               <a class="gov-btn gov-btn-primary" href="https&#58;//data.oregon.gov/Revenue-Expense/ODOT-Highway-Contracts-FY-2019-2016-Composite/fdus-r2ei/data" unselectable="on">Highway Construction Contracts</a><br></center></center></div></div></div></div>
		</div>
		<div class="col-md-3 col-sm-6">
			<div id="ctl00_ctl00_MainContentPlaceHolder_PageContentPlaceHolder_PageContentPlaceHolder_RichHtmlField8_label" style='display:none'></div><div id="ctl00_ctl00_MainContentPlaceHolder_PageContentPlaceHolder_PageContentPlaceHolder_RichHtmlField8__ControlWrapper_OregonRichHtmlField" class="ms-rtestate-field" style="display:inline" ><div class="gov-box-style-1"><div unselectable="on"><div unselectable="on">
         <img class="card-img-top" src="/transparency/PublishingImages/judicial.jpg" alt="Oregon Judicial Department" unselectable="on" style="width&#58;100%;" />
         <center unselectable="on" style="text-align&#58;left;"><h5 class="ms-rteElement-Heading5">Judicial Department Contracts<br></h5><p class="card-text" unselectable="on">Data and information on both contracts and amendments issued from the Oregon Judicial Department.<br></p></center></div></div><center unselectable="on"> 
      <a class="gov-btn gov-btn-primary" href="https&#58;//data.oregon.gov/Revenue-Expense/Judicial-Dept-Contracts-FY-2019-2015/3wxk-gaen/data" unselectable="on">Judicial Department Contracts</a><br></center></div></div>
		</div>
