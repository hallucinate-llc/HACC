			<script>
				// Pulls in the enterprise navigation and inserts as a child of .gov-header
				(function() {
					var headerEl = document.querySelector(".gov-header-navigation");

					var stickyPlaceholderEl = document.querySelector(".or-navbar-sticky-placeholder");
					var stickyWrapperEl = document.querySelector(".or-navbar-sticky-wrapper");
					var alertPlaceholderEl = document.querySelector(".or-state-alert-placeholder");

					var langEl = document.querySelector("#languageDiv");
					var langPlaceholderEl = document.querySelector('.gov-language-button');

					var navbarPlaceholderEl = document.querySelector(".or-navbar");
					var navbarEl = document.querySelector(".gov-navbar");

					var checkedOutMessageEl = document.querySelector(".checkedOutMessage");

					var govFullMenuEl = document.querySelector('gov-full-menu');
		
					stickyPlaceholderEl.remove();

					headerEl.insertAdjacentElement("afterbegin", stickyWrapperEl);
					
					alertPlaceholderEl.insertAdjacentHTML("afterbegin", "<gov-alert></gov-alert>");

					// swap .or-navbar with .gov-navbar
					stickyWrapperEl.insertBefore(navbarEl, navbarPlaceholderEl);
					navbarPlaceholderEl.remove();

					// Place checkedout message after gov-navbar
					if (checkedOutMessageEl) {
						//checkedOutMessageEl.remove();
						stickyWrapperEl.insertAdjacentElement("beforeend", checkedOutMessageEl);
					}

					// insert translation button before full menu toggle
					langPlaceholderEl.insertAdjacentElement('beforeend', langEl);
				})();
			</script>
		</div>

		
