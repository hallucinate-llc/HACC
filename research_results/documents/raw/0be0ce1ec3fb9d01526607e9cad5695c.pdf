	<ul class="nav">
		<li class="or-side-navigation-parent"><a href="/odhs/food/Pages/default.aspx">Food Resources</a><div>
			<ul class="or-side-navigation-submenu list-unstyled">
				<li class=""><a href="/odhs/food/Pages/snap.aspx">SNAP Food Benefits</a></li><li class=""><a href="/odhs/food/Pages/snap-replacement.aspx">SNAP Replacement Benefits</a></li><li class=""><a href="/odhs/food/Pages/snap-time-limits.aspx">SNAP Work Rules</a></li><li class=""><a href="/odhs/food/Pages/sebt.aspx">Summer EBT</a></li><li class=""><a href="/odhs/benefits/Pages/ebt.aspx">EBT Card Help</a></li><li class=""><a href="/odhs/food/Pages/free-food-events.aspx">Free Food and Resource Events</a></li>
