                    </div>

                    

                    

                        <div class="row">

                        <div class="col-md-3">
                            <!-- side navigation publishing data source -->
                            

                            <!-- side navigation menu -->
                            <nav id="OregonSideNavigation" aria-label="Site Navigation" class="or-side-navigation navmenu navmenu-default navmenu-fixed-left offcanvas-sm">
	<ul class="nav">
		<li class=""><a href="/odot/Business/Procurement/Pages/index.aspx">OPO Home </a></li><li class=""><a href="/odot/Business/Procurement/Pages/Contact.aspx">Contact Us/About</a></li><li class="or-side-navigation-current"><a href="/odot/Business/Procurement/Pages/HowTo.aspx" aria-current="page">Contracting with ODOT </a></li><li class="or-side-navigation-parent"><span class="or-side-navigation-unlinked-item">Highway &amp; Bridge Construction</span><div>
			<ul class="or-side-navigation-submenu list-unstyled">
				<li class=""><a href="/odot/Business/Procurement/Pages/Letting_Schedules.aspx">Letting Schedules</a></li><li class=""><a href="/odot/Business/Procurement/Pages/NTC.aspx">Notice to Contractors</a></li><li class=""><a href="/odot/Business/Procurement/Pages/Bid_Award.aspx">Bid and Award Information</a></li><li class=""><a href="/odot/Business/Procurement/Pages/Forms_Tips_and_Resources.aspx">Forms, Tips and Resources</a></li><li class=""><a href="/odot/Business/Procurement/Pages/Assent.aspx">Letter of Assent</a></li>
