      "id": "theorem:t2_notice_plus_valid_order_creates_noninterference_prohibition",
      "kind": "deontic_theorem",
      "statement": "If a person has notice of an effective order, that person is prohibited from interfering with conduct authorized by the order.",
      "status": "model_rule_pending_case_law_mapping"
    },
