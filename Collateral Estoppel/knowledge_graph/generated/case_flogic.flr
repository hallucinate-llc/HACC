% Deontic rules
deontic(P, person:benjamin_barber, act_within_valid_guardian_scope, person:jane_cortez) :- holds(f_client_prior_appointment).
deontic(F, person:benjamin_barber, interfere_with_guardian_or_housing_process, process:hacc_housing_contract) :- holds(f_client_prior_appointment), holds(f_client_benjamin_housing_interference).
deontic(O, person:benjamin_barber, comply_with_order_or_seek_relief, order:prior_guardianship_order) :- holds(f_client_prior_appointment), holds(f_client_benjamin_order_disregard).
deontic(F, person:solomon, abuse_contact_or_control_property, person:jane_cortez) :- holds(f_solomon_actual_notice_on_2025_11_17), holds(f_restraining_order_granted), holds(f_restraining_order_in_effect), holds(f_restraining_order_contact_restrictions), holds(f_restraining_order_property_restrictions).
deontic(F, person:solomon, enter_or_remain_at_petitioner_residence, location:10043_se_32nd_ave) :- holds(f_solomon_actual_notice_on_2025_11_17), holds(f_restraining_order_granted), holds(f_restraining_order_residence_restrictions).
deontic(O, person:solomon, appear_and_answer_show_cause, proceeding:related_order_hearing) :- holds(f_restraining_order_no_further_service_needed), holds(f_client_solomon_failed_appearance).
deontic(O, person:solomon, seek_hearing_or_comply_with_existing_order, order:eppdapa_restraining_order) :- holds(f_restraining_order_granted), holds(f_restraining_order_in_effect), holds(f_solomon_service_position_statement).
deontic(F, person:solomon, adopt_self_help_noncooperation_posture, order:eppdapa_restraining_order) :- holds(f_restraining_order_granted), holds(f_restraining_order_in_effect), holds(f_solomon_noncooperation_statement).
deontic(O, org:hacc, process_housing_consistent_with_valid_guardian_authority, person:jane_cortez) :- holds(f_hacc_process_exists), holds(f_client_prior_appointment).
deontic(O, org:hacc, document_basis_for_household_composition_or_lease_adjustment, household:jane_cortez_household) :- holds(f_hacc_lease_adjustment_effective_2026_01_01).
deontic(P, case:guardianship_collateral_estoppel, treat_solomon_hacc_interference_as_inference_not_direct_proof, person:solomon) :- holds(f_hacc_named_notice_to_solomon_order_not_found).
deontic(F, person:solomon, relitigate_precluded_issue, issue:guardianship_authority) :- holds(f_collateral_estoppel_candidate), holds(f_client_solomon_barred_refile).
deontic(O, person:solomon, seek_clarification_or_relief_through_court, order:eppdapa_restraining_order) :- holds(f_feed_ev_solomon_ack_heard_restraining_order), holds(f_restraining_order_in_effect).
deontic(F, person:solomon, condition_compliance_on_additional_service, order:eppdapa_restraining_order) :- holds(f_feed_ev_solomon_wait_for_service_statement), holds(f_restraining_order_no_further_service_needed).
deontic(F, person:solomon, intentional_noncooperation_with_effective_order, order:eppdapa_restraining_order) :- holds(f_feed_ev_solomon_not_incentivized_statement), holds(f_restraining_order_in_effect).
deontic(O, person:solomon, recognize_existing_order_status, order:eppdapa_restraining_order) :- holds(f_feed_ev_solomon_ack_already_have_order), holds(f_restraining_order_in_effect).
deontic(F, person:solomon, assert_order_ineffective_without_court_relief, order:eppdapa_restraining_order) :- holds(f_feed_ev_solomon_order_not_in_effect_statement), holds(f_restraining_order_in_effect).
deontic(O, person:solomon, file_motion_to_modify_or_vacate_before_noncompliance, order:eppdapa_restraining_order) :- holds(f_feed_ev_solomon_judge_overturn_statement), holds(f_restraining_order_in_effect).
deontic(O, org:hacc, avoid_third_party_housing_contact_with_restrained_person_and_document_response, person:jane_cortez) :- holds(f_feed_ev_hacc_notice_brother_calls_after_granted_order), holds(f_feed_ev_hacc_notice_third_party_contact_with_restrained_person).

% Helper: strict mode
holds(F) :- fact(F, _, status(verified), value(true)).
% Helper: inclusive mode
holds_inclusive(F) :- fact(F, _, status(verified), value(true)).
holds_inclusive(F) :- fact(F, _, status(alleged), value(true)).
